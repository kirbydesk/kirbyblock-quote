{
  "content": {
    "quote":  { "align": "left", "size": "lg", "mode": "textarea" },
    "author": { "align": "left" }
  },
  "layout": {
    "padding-top": "large",
    "padding-bottom": "large",
    "padding-left": true,
    "padding-right": true,
    "radius-top-left": false,
    "radius-top-right": false,
    "radius-bottom-left": false,
    "radius-bottom-right": false
  },
  "style": {
    "theme": "default"
  },
  "grid": {
    "grid-size-sm": 12,
    "grid-size-md": 12,
    "grid-size-lg": 12,
    "grid-size-xl": 12,
    "grid-offset-sm": 0,
